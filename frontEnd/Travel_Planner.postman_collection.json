{
  "info": {
    "name": "Travel Planner API",
    "description": "Complete API documentation for the Travel Planner backend project. This collection contains all endpoints grouped by their controllers: Authentication, User operations, and Admin operations.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth Controller",
      "description": "Endpoints corresponding to Authentication (Login & Register).",
      "item": [
        {
          "name": "User Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"test@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "response": [
            {
              "name": "200 - Successful Login",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"username\": \"test@example.com\",\n  \"role\": \"USER\",\n  \"token\": \"eyJhbGciOiJIUzI1NiJ9...\"\n}"
            }
          ]
        },
        {
          "name": "User Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"johndoe\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "response": [
            {
              "name": "201 - User Created",
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"username\": \"johndoe\",\n  \"role\": \"USER\",\n  \"token\": \"eyJhbGciOiJIUzI1NiJ9...\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "User Controller",
      "description": "Endpoints related to standard user actions, destinations discovery, and visits.",
      "item": [
        {
          "name": "Get Approved Destinations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/user/approved-destinations?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "approved-destinations"],
              "query": [
                {
                  "key": "page",
                  "value": "0",
                  "description": "Page number (0-indexed)"
                },
                {
                  "key": "size",
                  "value": "10",
                  "description": "Size of each page"
                }
              ]
            }
          },
          "response": [
            {
              "name": "200 - Page of Destinations",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"content\": [\n    {\n      \"id\": 1,\n      \"name\": \"France\",\n      \"capital\": \"Paris\",\n      \"region\": \"Europe\",\n      \"population\": 67000000,\n      \"currency\": \"EUR\",\n      \"flagUrl\": \"https://example.com/flags/fr.png\",\n      \"approved\": true\n    }\n  ],\n  \"pageable\": { \"pageNumber\": 0, \"pageSize\": 10 },\n  \"totalElements\": 1,\n  \"totalPages\": 1\n}"
            }
          ]
        },
        {
          "name": "Get Destination By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/user/destination/1",
