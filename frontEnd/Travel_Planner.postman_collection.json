              "path": ["api", "user", "destination", "1"]
            }
          },
          "response": [
            {
              "name": "200 - Destination Details",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"id\": 1,\n  \"name\": \"France\",\n  \"capital\": \"Paris\",\n  \"region\": \"Europe\",\n  \"population\": 67000000,\n  \"currency\": \"EUR\",\n  \"flagUrl\": \"https://example.com/flags/fr.png\",\n  \"approved\": true\n}"
            }
          ]
        },
        {
          "name": "Search Destinations By Name",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/user/destinations/search?name=France",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "destinations", "search"],
              "query": [
                {
                  "key": "name",
                  "value": "France",
                  "description": "Name or partial name of the destination"
                }
              ]
            }
          },
          "response": [
            {
              "name": "200 - List of Destinations",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "[\n  {\n    \"id\": 1,\n    \"name\": \"France\",\n    \"capital\": \"Paris\",\n    \"region\": \"Europe\",\n    \"population\": 67000000,\n    \"currency\": \"EUR\",\n    \"flagUrl\": \"https://example.com/flags/fr.png\",\n    \"approved\": true\n  }\n]"
            }
          ]
        },
        {
          "name": "Mark Want To Visit",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/user/destination/1/want-to-visit?userId=123",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "destination", "1", "want-to-visit"],
              "query": [
                {
                  "key": "userId",
                  "value": "123",
                  "description": "ID of the user wanting to visit"
                }
              ]
            }
          },
          "response": [
            {
              "name": "200 - Marked Successfully",
              "status": "OK",
              "code": 200,
